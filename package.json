{
  "name": "@polly-fe/design-tokens",
  "version": "1.4.1",
  "type": "module",
  "description": "Centralized design tokens for Polly applications",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "tokens/",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/css-variables.min.css",
    "./mixins": "./dist/mixins.scss",
    "./tokens": "./dist/tokens.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node build-tokens.js && npm run build:package",
    "build:package": "node scripts/build-package.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "postinstall": "npm run build",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish"
  },
  "keywords": [
    "design-tokens",
    "css-variables",
    "scss",
    "theme",
    "polly",
    "design-system"
  ],
  "author": "Polly Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElucidataInc/polly-design-system.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
