{
  "base": {
    "width": "50rem",
    "background": "{color.standard.white}",
    "borderradius": "0.5rem",
    "boxshadow": "0 0 1.25rem 0 rgba(0, 0, 0, 0.08), 0 0 0.25rem 0 rgba(0, 0, 0, 0.24)",
    "margin": "0 0 1em 0",
    "padding": "0.25rem 0.25rem 0.375rem 0.625rem",
    "borderleftwidth": "0.375rem",
    "borderleftstyle": "solid"
  },
  "content": {
    "borderwidth": "0",
    "display": "grid",
    "gridtemplatecolumns": "auto 1fr auto",
    "gap": "0.5rem"
  },
  "icon": {
    "padding": "0.5rem 0",
    "fontsize": "1.25rem",
    "height": "1.5rem",
    "width": "1.5rem"
  },
  "text": {
    "display": "flex",
    "flexdirection": "column",
    "gap": "0.25rem",
    "margin": "0"
  },
  "summary": {
    "fontweight": "400",
    "padding": "0.375rem 0"
  },
  "detail": {
    "margin": "0",
    "color": "{color.primary.neutral}"
  },
  "closebutton": {
    "background": "{color.standard.white}",
    "backgroundhover": "{color.neutral.purple|mix:10:white}",
    "backgroundactive": "{color.neutral.purple|mix:25:white}",
    "border": "none",
    "borderradius": "50%",
    "padding": "0.375rem",
    "right": "0.1rem",
    "transition": "background-color 0.3s ease",
    "iconcolor": "{color.primary.neutral}",
    "iconsize": "1.5rem",
    "iconfontsize": "1.25rem"
  },
  "severity": {
    "info": {
      "bordercolor": "{color.primary.neutral|mix:60:black}",
      "iconcolor": "{color.primary.neutral|mix:60:black}"
    },
    "success": {
      "bordercolor": "{color.primary.blue}",
      "iconcolor": "{color.primary.blue}"
    },
    "warn": {
      "bordercolor": "{color.primary.orange|mix:70:black}",
      "iconcolor": "{color.primary.orange|mix:70:black}"
    },
    "error": {
      "bordercolor": "{color.primary.red|mix:70:black}",
      "iconcolor": "{color.primary.red|mix:70:black}"
    }
  },
  "variant": {
    "vertical": {
      "padding": "0.375rem 0.375rem 0.375rem 0.875rem",
      "content": {
        "alignitems": "center"
      },
      "icon": {
        "padding": "0.25rem 0"
      },
      "text": {
        "alignitems": "center",
        "flexdirection": "row",
        "gap": "0.5rem"
      },
      "summary": {
        "padding": "0"
      }
    }
  }
}
