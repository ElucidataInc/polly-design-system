      "middle": {
        "strokearray": "89, 200",
        "strokeoffset": "-35px"
      },
      "end": {
        "strokearray": "89, 200",
        "strokeoffset": "-124px"
      }
    },
    "color": {
      "start": {
        "stroke": "{color.brand.alt.dark|mix:90:black}"
      },
      "end": {
        "stroke": "{color.brand.alt.dark|mix:90:black}"
      }
    }
