{
  "stroke": {
    "color": {
      "default": "{color.brand.alt.dark|mix:90:black}"
    }
  },
  "animation": {
    "dash": {
      "duration": "1.5s",
      "timing": "ease-in-out",
      "iteration": "infinite"
    },
    "color": {
