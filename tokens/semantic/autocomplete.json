{
  "base": {
    "transitionduration": "0.3s ease-in-out",
    "input": {
      "width": "100%",
      "padding": {
        "default": "0.5rem 0.75rem",
        "withdropdown": "0.5rem 2.25rem 0.5rem 0.75rem"
      },
      "borderradius": {
        "withdropdown": {
          "start": "0.25rem",
          "end": "0.25rem"
        }
      },
      "color": "{color.primary.neutral|mix:60:black}"
    },
    "loader": {
      "default": {
        "inset": "1rem"
      },
      "dropdown": {
        "padding-x": "1.5rem",
        "width": "1.5rem"
      },
      "position": {
        "right": {
          "withdropdown": "2.75rem"
        }
      }
    },
    "dropdown": {
      "backgroundcolor": "transparent",
      "color": "{color.primary.neutral|mix:90:white}",
      "border": "0",
      "fontsize": "1.25rem",
      "position": {
        "right": "0.5rem"
      },
      "alignself": "center"
    },
    "multiple": {
      "input": {
        "display": "flex",
        "flexwrap": "wrap",
        "gap": "0.375rem"
      },
      "chip": {
        "backgroundcolor": "{color.secondary.blue|mix:10:white}",
        "color": "{color.secondary.blue|mix:80:black}",
        "border": "1px solid {color.secondary.blue|mix:20:white}",
        "borderradius": "1rem",
        "padding": "0.25rem 0.375rem 0.25rem 0.625rem",
        "margin": "0",
        "gap": "0.25rem",
        "label": {
          "fontsize": "0.6875rem",
          "lineheight": "1rem",
          "fontweight": "500",
          "margintop": "0",
          "gap": "0.5rem"
        },
        "removeicon": {
          "fontsize": "1rem",
          "marginleft": "0"
        }
      },
      "inputchip": {
        "margin": "0"
      }
    },
    "input": {
      "multiple": {
        "align-items": "center",
        "background": "transparent",
        "border": "none",
        "border-radius": "0",
        "box-shadow": "none",
        "cursor": "text",
        "display": "flex",
        "flex-wrap": "wrap",
        "gap": "0.25rem",
        "list-style-type": "none",
        "margin": "0",
        "outline-color": "transparent",
        "overflow": "hidden",
        "padding": "0.25rem 0.25rem",
        "width": "100%",
        "focus": {
          "border-color": "transparent",
          "box-shadow": "none",
          "outline": "none",
          "outline-offset": "0"
        },
        "chip": {
          "paddinginlinestart": "0.5rem",
          "paddinginlineend": "0.5rem"
        }
      }
    },
    "overlay": {
      "background": "#fff",
      "border": "0",
      "borderradius": "0.5rem",
      "boxshadow": "0 0 2px 0 #0000001F, 0 2px 4px 0 #00000014",
      "margin": "auto",
      "padding": "0.5rem 0",
      "list": {
        "padding": "0",
        "gap": "0"
      },
      "option": {
        "fontsize": "0.875rem",
        "lineheight": "1.25rem",
        "fontweight": "400",
        "backgroundcolor": "transparent",
        "color": "{color.primary.neutral|mix:60:black}",
        "border": "0",
        "margin": "0",
        "padding": "0.625rem 0.625rem 0.625rem 0.875rem",
        "wordwrap": "break-word",
        "hover": {
          "backgroundcolor": "{color.neutral.purple|mix:10:white}",
          "color": "{color.primary.neutral|mix:60:black}"
        },
        "highlight": {
          "backgroundcolor": "{color.neutral.purple|mix:25:white}",
          "color": "{color.secondary.purple|mix:60:black}"
        }
      },
      "emptymessage": {
        "fontsize": "0.875rem",
        "lineheight": "1.25rem",
        "fontweight": "400",
        "backgroundcolor": "transparent",
        "color": "{color.primary.neutral|mix:60:black}",
        "padding": "0.625rem 0.625rem 0.625rem 0.875rem"
      }
    },
    "disabled": {
      "opacity": "0.4"
    }
  },
  "tonal": {
    "input": {
      "backgroundcolor": {
        "default": "{color.secondary.purple|mix:15:white}",
        "hover": "{color.secondary.purple|mix:25:white}",
        "focus": "{color.secondary.purple|mix:40:white}",
        "disabled": "{color.secondary.purple|mix:15:white}"
      },
      "color": {
        "default": "{color.secondary.purple|mix:60:black}",
        "hover": "{color.secondary.purple|mix:80:black}",
        "focus": "{color.neutral.purple|mix:60:black}",
        "disabled": "{color.secondary.purple|mix:60:black}"
      },
      "border": "none",
      "borderradius": "0.5rem",
      "outline": "none",
      "placeholder": {
        "color": "{color.secondary.purple|mix:60:black}"
      }
    },
    "icon": {
      "color": {
        "default": "{color.secondary.purple|mix:80:black}",
        "disabled": "{color.secondary.purple|mix:80:black}"
      },
      "opacity": "1"
    },
    "dropdown": {
      "separatorline": {
        "backgroundcolor": "{color.neutral.purple|mix:40:white}",
        "position": "absolute",
        "inset": "0 auto 0 0",
        "width": "1px"
      },
      "icon": {
        "color": "{color.secondary.purple|mix:80:black}"
      }
    },
    "disabled": {
      "opacity": "1"
    }
  },
  "icon": {
    "left": {
      "disabled": {
        "color": "{color.primary.neutral|mix:60:white}",
        "opacity": "0.4"
      }
    }
  },
  "sizes": {
    "small": {
      "fontsize": "0.75rem"
    },
    "default": {
      "fontsize": "0.875rem"
    },
    "large": {
      "fontsize": "1rem"
    }
  }
}
