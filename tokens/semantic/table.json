{
  "base": {
    "fontfamily": "{font.family.inter}",
    "resizable": {
      "columnresizer": {
        "border": "1px solid transparent",
        "cursor": "col-resize",
        "display": "block",
        "height": "100%",
        "margin": "0",
        "padding": "0",
        "position": "absolute",
        "right": "0",
        "top": "0",
        "width": "0.5rem"
      },
      "columnresizeindicator": {
        "background": "{color.neutral.purple|mix:5:white}",
        "position": "absolute",
        "width": "1px",
        "zindex": "10"
      },
      "thead": {
        "th": {
          "overflow": "hidden",
          "whitespace": "nowrap",
          "columnresizable": {
            "backgroundclip": "padding-box",
            "position": "relative"
          }
        }
      },
      "tbody": {
        "th": {
          "overflow": "hidden",
          "whitespace": "nowrap"
        }
      },
      "tfoot": {
        "th": {
          "overflow": "hidden",
          "whitespace": "nowrap"
        }
      },
      "fit": {
        "lastcolumnresizer": {
          "display": "none"
        }
      }
    },
    "header": {
      "row": {
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}"
      },
      "cell": {
        "fontsize": "0.75rem",
        "fontweight": "500",
        "lineheight": "1rem",
        "background": "{color.standard.white}",
        "color": "{color.neutral.purple|mix:60:black}",
        "padding": "0.625rem 1rem",
        "border": "0",
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}",
        "coloralternate": {
          "background": "{color.secondary.blue|mix:5:white}"
        }
      }
    },
    "body": {
      "row": {
        "background": "transparent",
        "odd": {
          "background": "{color.neutral.purple|mix:5:white}"
        },
        "hover": {
          "background": "{color.neutral.purple|mix:5:white}",
          "odd": {
            "background": "{color.neutral.purple|mix:10:white}"
          }
        },
        "selected": {
          "background": "{color.neutral.blue|mix:20:white}",
          "border": "1px solid {color.primary.neutral|mix:60:white}"
        },
        "active": {
          "background": "{color.neutral.purple|mix:10:white}",
          "odd": {
            "background": "{color.neutral.purple|mix:20:white}"
          }
        }
      },
      "cell": {
        "fontsize": "0.75rem",
        "fontweight": "400",
        "lineheight": "1rem",
        "color": "{color.primary.neutral|mix:60:black}",
        "border": "0",
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}",
        "padding": "0.5rem 0.75rem",
        "size": {
          "large": {
            "padding": "0.5rem 1rem"
          },
          "medium": {
            "padding": "0.5rem 0.75rem"
          },
          "small": {
            "padding": "0.375rem 0.5rem"
          }
        }
      }
    }
  },
  "skeleton": {
    "header": {
      "row": {
        "border": "0",
        "background": "transparent"
      },
      "cell": {
        "background": "transparent",
        "border": "0",
        "padding": "0.625rem 1rem"
      }
    },
    "body": {
      "cell": {
        "padding": "0.875rem 1rem"
      }
    }
  },
  "clear": {
    "header": {
      "row": {
        "border": "0"
      },
      "cell": {
        "color": "{color.neutral.purple|mix:60:black}"
      }
    },
    "body": {
      "row": {
        "background": "{color.standard.white}",
        "hover": {
          "background": "{color.standard.white}"
        },
        "active": {
          "background": "{color.standard.white}"
        }
      },
      "cell": {
        "border": "0"
      }
    }
  },
  "vertical": {
    "container": {
      "border": "0.5px solid {color.neutral.purple|mix:20:white}"
    },
    "header": {
      "cell": {
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}"
      }
    },
    "body": {
      "cell": {
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}"
      }
    }
  },
  "rounded": {
    "container": {
      "borderradius": "1rem",
      "overflow": "hidden"
    },
    "tablecontainer": {
      "borderradius": "1rem"
    }
  },
  "qubittable": {
    "fontfamily": "{font.family.inter}",
    "flexscrollable": {
      "tablecontainer": {
        "virtualscroller": {
          "overflow": "hidden",
          "minheight":"45rem"
        },
        "virtualscrollercontent": {
          "height": "100%"
        }
      }
    },
    "resizable": {
      "columnresizer": {
        "borderright": "1px solid transparent",
        "cursor": "col-resize",
        "display": "block",
        "height": "100%",
        "margin": "0",
        "padding": "0",
        "position": "absolute",
        "right": "0",
        "top": "0",
        "width": "0.5rem",
        "hover": {
          "borderright": "1px solid {color.neutral.purple|mix:20:white}"
        }
      },
      "thead": {
        "th": {
          "overflow": "hidden",
          "whitespace": "nowrap",
          "columnresizable": {
            "backgroundclip": "padding-box",
            "position": "relative"
          }
        }
      },
      "tbody": {
        "th": {
          "overflow": "hidden",
          "whitespace": "nowrap"
        }
      },
      "tfoot": {
        "th": {
          "overflow": "hidden",
          "whitespace": "nowrap"
        }
      },
      "fit": {
        "lastcolumnresizer": {
          "display": "none"
        }
      }
    },
    "header": {
      "row": {
        "display": "flex",
        "alignitems": "center"
      },
      "cell": {
        "color": "{color.neutral.purple|mix:60:black}",
        "fontsize": "0.75rem",
        "fontweight": "500",
        "lineheight": "1rem",
        "background": "{color.standard.white}",
        "border": "0",
        "display": "flex",
        "alignitems": "center",
        "flex": "1 0",
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}"
      }
    },
    "body": {
      "row": {
        "display": "flex",
        "alignitems": "center",
        "rowgroupheader": {
          "background": "{color.standard.white}",
          "borderbottom": "1px solid {color.primary.purple|mix:10:white}"
        }
      },
      "cell": {
        "fontsize": "0.75rem",
        "fontweight": "500",
        "lineheight": "1rem",
        "display": "flex",
        "alignitems": "center",
        "flex": "1 0",
        "border": "none"
      }
    },
    "types": {
      "island": {
        "header": {
          "row": {
            "background": "{color.standard.white}",
            "border": "1px solid {color.secondary.purple|mix:10:white}",
            "borderradius": "0.25rem",
            "marginbottom": "0.25rem"
          },
          "cell": {
            "background": "{color.standard.white}",
            "border": "none",
            "padding": "0.125rem 1rem"
          }
        },
        "body": {
          "row": {
            "background": "{color.standard.white}",
            "border": "1px solid {color.secondary.purple|mix:10:white}",
            "borderradius": "0.25rem",
            "marginbottom": "0.25rem",
            "padding": "0.25rem 0",
            "hover": {
              "background": "{color.neutral.purple|mix:10:white}"
            },
            "selected": {
              "background": "{color.neutral.purple|mix:20:white}"
            }
          }
        }
      },
      "simplified": {
        "header": {
          "cell": {
            "background": "{color.standard.white}",
            "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
            "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}",
            "size": {
              "large": {
                "padding": "0.625rem 1rem"
              },
              "medium": {
                "padding": "0.625rem 0.75rem"
              },
              "small": {
                "padding": "0.5rem"
              }
            },
            "coloralternate": {
              "background": "{color.secondary.blue|mix:5:white}"
            }
          }
        },
        "body": {
          "row": {
            "background": "transparent",
            "border": "0",
            "even": {
              "background": "transparent"
            }
          },
          "cell": {
            "background": "{color.standard.white}",
            "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}",
            "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
            "size": {
              "large": {
                "padding": "0.5rem 1rem"
              },
              "medium": {
                "padding": "0.5rem 0.75rem"
              },
              "small": {
                "padding": "0.375rem 0.5rem"
              }
            }
          }
        }
      },
      "display": {
        "header": {
          "cell": {
            "background": "{color.standard.white}",
            "borderbottom": "1px solid {color.primary.neutral|mix:20:white}",
            "size": {
              "large": {
                "padding": "0.125rem 1rem"
              },
              "medium": {
                "padding": "0.375rem 0.75rem"
              },
              "small": {
                "padding": "0.25rem 0.5rem"
              }
            },
            "coloralternate": {
              "background": "{color.neutral.purple|mix:10:white}"
            }
          }
        },
        "body": {
          "row": {
            "background": "{color.primary.neutral|mix:5:white}",
            "border": "0",
            "even": {
              "background": "{color.standard.white}"
            },
            "hover": {
              "background": "{color.neutral.purple|mix:10:white}"
            },
            "selected": {
              "background": "{color.neutral.purple|mix:20:white}"
            }
          },
          "cell": {
            "size": {
              "large": {
                "padding": "0.5rem 1rem"
              },
              "medium": {
                "padding": "0.5rem 0.75rem"
              },
              "small": {
                "padding": "0.25rem 0.5rem"
              }
            }
          }
        }
      },
      "flatline": {
        "body": {
          "row": {
            "background": "transparent",
            "border": "none",
            "borderbottom": "1px solid {color.neutral.purple|mix:15:white}",
            "hover": {
              "background": "{color.neutral.purple|mix:10:white}"
            },
            "selected": {
              "background": "{color.neutral.purple|mix:20:white}"
            }
          }
        }
      }
    },
    "sizes": {
      "large": {
        "header": {
          "gridgap": "0.375rem",
          "height": "2.25rem"
        },
        "body": {
          "gridgap": "0.375rem",
          "padding": "0.575rem"
        }
      },
      "medium": {
        "header": {
          "gridgap": "0.25rem",
          "height": "2.25rem"
        },
        "body": {
          "gridgap": "0.25rem"
        }
      },
      "small": {
        "header": {
          "gridgap": "0.25rem",
          "height": "2rem"
        },
        "body": {
          "gridgap": "0.25rem"
        }
      }
    }
  },
  "qubitcoscientisttable": {
    "container": {
      "border": "1px solid {color.neutral.purple|mix:20:white}",
      "borderradius": "0.5rem"
    },
    "columnresizer": {
      "borderright": "1px solid {color.neutral.purple|mix:20:white}"
    },
    "header": {
      "row": {
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}"
      },
      "cell": {
        "fontsize": "0.75rem",
        "fontweight": "500",
        "lineheight": "1rem",
        "background": "{color.standard.white}",
        "color": "{color.neutral.purple|mix:60:black}",
        "padding": "0.625rem 1rem",
        "border": "0",
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}",
        "coloralternate": {
          "background": "{color.secondary.blue|mix:5:white}"
        }
      }
    },
    "body": {
      "row": {
        "background": "transparent",
        "odd": {
          "background": "{color.neutral.purple|mix:5:white}"
        },
        "hover": {
          "background": "{color.neutral.blue|mix:5:white}",
          "odd": {
            "background": "{color.neutral.purple|mix:10:white}"
          }
        },
        "selected": {
          "background": "{color.neutral.blue|mix:20:white}",
          "border": "1px solid {color.primary.neutral|mix:60:white}",
          "odd": {
            "background": "{color.neutral.purple|mix:20:white}"
          }
        },
        "active": {
          "background": "{color.neutral.blue|mix:20:white}",
          "odd": {
            "background": "{color.neutral.purple|mix:20:white}"
          }
        }
      },
      "cell": {
        "fontsize": "0.75rem",
        "fontweight": "400",
        "lineheight": "1rem",
        "color": "{color.primary.neutral|mix:60:black}",
        "border": "0",
        "borderright": "0.5px solid {color.neutral.purple|mix:20:white}",
        "borderbottom": "0.5px solid {color.neutral.purple|mix:20:white}",
        "padding": "0.5rem 0.75rem",
        "size": {
          "large": {
            "padding": "0.5rem 1rem"
          },
          "medium": {
            "padding": "0.5rem 0.75rem"
          },
          "small": {
            "padding": "0.375rem 0.5rem"
          }
        }
      }
    }
  }
}
